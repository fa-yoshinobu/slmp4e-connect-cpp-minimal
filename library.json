{
  "name": "slmp-connect-cpp-minimal",
  "version": "0.3.0",
  "description": "Compact SLMP binary client for Arduino-compatible TCP transports with fixed caller-owned buffers.",
  "keywords": [
    "slmp",
    "melsec",
    "plc",
    "arduino",
    "tcp",
    "wifi",
    "ethernet",
    "embedded"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/fa-yoshinobu/plc-comm-slmp-cpp-minimal.git"
  },
  "authors": [
    {
      "name": "fa-yoshinobu",
      "maintainer": true
    }
  ],
  "license": "MIT",
  "homepage": "https://github.com/fa-yoshinobu/plc-comm-slmp-cpp-minimal",
  "frameworks": [
    "arduino"
  ],
  "platforms": [
    "espressif32",
    "raspberrypi"
  ],
  "headers": [
    "slmp_minimal.h",
    "slmp_arduino_transport.h"
  ],
  "export": {
    "exclude": [
      ".github",
      ".pio",
      "AGENTS.md",
      "TODO.md",
      "docs/maintainer",
      "docs/validation",
      "local_folder",
      "platformio",
      "scripts",
      "tests",
      "*.gcda",
      "*.gcno",
      "coverage-summary.txt",
      "coverage.xml",
      "coverage.html",
      "release-notes.md",
      "size-report.md",
      "size-report.json"
    ]
  }
}
